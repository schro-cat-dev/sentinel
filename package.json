{
  "name": "@schro-cat-dev/sentinel",
  "version": "0.1.0-alpha.2",
  "description": "TypeScript client SDK for intelligent log-to-task automation. Detects events from logs, auto-generates remediation tasks, and dispatches actions. Backend server planned in Go.",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && rollup -c",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "logging",
    "task-automation",
    "event-detection",
    "integrity",
    "hash-chain",
    "pii-masking",
    "typescript"
  ],
  "author": "sy (schro-cat-dev)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.19.30",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "rollup": "^4.56.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  }
}
